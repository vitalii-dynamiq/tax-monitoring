DATABASE_URL=postgresql+asyncpg://taxlens:taxlens@localhost:5432/taxlens
DATABASE_URL_SYNC=postgresql://taxlens:taxlens@localhost:5432/taxlens
API_KEY=your-secure-api-key-here
ENVIRONMENT=development
CORS_ORIGINS=*
DEBUG=false
LOG_LEVEL=INFO

# Anthropic API (required for tax monitoring)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=16384
ANTHROPIC_TIMEOUT_SECONDS=300
ANTHROPIC_MAX_SEARCH_USES=10
ANTHROPIC_MAX_AGENT_TURNS=20

# Monitoring scheduler
MONITORING_MAX_CONCURRENT_JOBS=5
MONITORING_JOB_TIMEOUT_SECONDS=900
MONITORING_SCHEDULER_INTERVAL_SECONDS=60
